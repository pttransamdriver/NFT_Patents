# ============================================================
# Patent NFT — AI Service Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Required ---
OPENAI_API_KEY=sk-...

# --- LangSmith (free tier — enable for portfolio tracing screenshots) ---
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nft-patents-rag

# --- Service URLs ---
# URL of the Express backend (for agent tools that call /api/patents/*)
EXPRESS_BACKEND_URL=http://localhost:3001

# --- Model selection ---
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Paths ---
# Path to patents-db.json relative to ai_service/ directory
PATENTS_DB_PATH=../backend/patents-db.json
# Where ChromaDB persists its vector index
CHROMA_PERSIST_DIR=./chroma_db
